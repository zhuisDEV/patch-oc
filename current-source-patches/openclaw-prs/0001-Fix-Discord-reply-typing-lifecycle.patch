+    log: (message) => {
+      ctx.runtime.error?.(danger(message));
+    },
+  });
+  ctx.replyTypingFeedback = replyTypingFeedback;
+  void replyTypingFeedback.onReplyStart().catch((err) => {
+    ctx.runtime.error?.(danger(`discord accepted typing failed: ${String(err)}`));
+  });
